# Сессия прогресса квиза (встраивается в клиент при сборке / dev).
# Имеет приоритет меньше, чем VITE_QUIZ_SESSION_MS (если задано оба — используется только MS).
#
# Длительность в часах (дробное число через точку):
# VITE_QUIZ_SESSION_HOURS=6
#
# Либо явно в миллисекундах:
# VITE_QUIZ_SESSION_MS=21600000

# Vercel Blob upload endpoint использует серверную переменную.
# Не добавляйте префикс VITE_, чтобы токен не попал в браузер.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Срок действия токенов комнаты (в часах, только сервер).
# Ссылка для участников (?t=...) — ROOM_ACCESS_TOKEN_TTL_HOURS
# Права редактирования организатора — ROOM_OWNER_TOKEN_TTL_HOURS
# ROOM_ACCESS_TOKEN_TTL_HOURS=168
# ROOM_OWNER_TOKEN_TTL_HOURS=720

# Аудио для встроенных карточек «Музыка».
# Вставьте публичные URL файлов из Vercel Blob.
# VITE_MUSIC_AUDIO_1=https://...
# VITE_MUSIC_AUDIO_2=https://...
# VITE_MUSIC_AUDIO_3=https://...
# VITE_MUSIC_AUDIO_4=https://...
# VITE_MUSIC_AUDIO_5=https://...
# VITE_MUSIC_AUDIO_6=https://...
# VITE_MUSIC_AUDIO_7=https://...
# VITE_MUSIC_AUDIO_8=https://...
# VITE_MUSIC_AUDIO_9=https://...
# VITE_MUSIC_AUDIO_10=https://...

# Видео для встроенных карточек «Кино».
# Вставьте публичные URL файлов из Vercel Blob.
# VITE_MOVIE_VIDEO_1=https://...
# VITE_MOVIE_VIDEO_2=https://...
# VITE_MOVIE_VIDEO_3=https://...
# VITE_MOVIE_VIDEO_4=https://...
# VITE_MOVIE_VIDEO_5=https://...
# VITE_MOVIE_VIDEO_6=https://...
# VITE_MOVIE_VIDEO_7=https://...
# VITE_MOVIE_VIDEO_8=https://...
# VITE_MOVIE_VIDEO_9=https://...
# VITE_MOVIE_VIDEO_10=https://...
